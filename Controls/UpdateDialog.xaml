<Window x:Class="陈叔叔工具箱.Controls.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Width="440" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="#2d2d2d"
            CornerRadius="12"
            BorderBrush="#33ffffff"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="20,16,20,12">
                <TextBlock Text="&#xE895; 发现新版本"
                           FontFamily="Microsoft YaHei"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="#ffffff"
                           VerticalAlignment="Center" />
                <Button Content="&#xE8BB;"
                        HorizontalAlignment="Right"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12" Foreground="#cccccc"
                        Width="32" Height="32"
                        Click="OnCloseClick"
                        Style="{StaticResource SmallCaptionButton}" />
            </Grid>

            <!-- 分隔线 -->
            <Border Grid.Row="1" Height="1" Background="#1effffff" />

            <!-- 内容 -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="20,16,20,12">
                <StackPanel>
                    <!-- 版本对比 -->
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="当前版本"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="11" Foreground="#777777"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtCurrentVersion"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#aaaaaa"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="→"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="24" Foreground="#60cdff"
                                       VerticalAlignment="Center"
                                       Margin="24,0" />
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="最新版本"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="11" Foreground="#777777"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtLatestVersion"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#60cdff"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 更新内容 -->
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="更新内容"
                                       FontFamily="Microsoft YaHei"
                                       FontWeight="SemiBold"
                                       FontSize="12" Foreground="#ffffff"
                                       Margin="0,0,0,6" />
                            <TextBlock x:Name="TxtChangelog"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12" Foreground="#cccccc"
                                       TextWrapping="Wrap"
                                       MaxHeight="100" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="3" Background="#252525"
                    CornerRadius="0,0,12,12"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="稍后提醒"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" Foreground="#cccccc"
                            Background="Transparent"
                            BorderBrush="#33ffffff" BorderThickness="1"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnRemindLaterClick"
                            Margin="0,0,10,0" />
                    <Button x:Name="BtnUpdate"
                            Content="立即更新"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="#ffffff"
                            Background="#60cdff"
                            BorderThickness="0"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnUpdateClick"
                            Style="{StaticResource AccentButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
