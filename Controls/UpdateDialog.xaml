<Window x:Class="陈叔叔工具箱.Controls.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Width="480" Height="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="#2d2d2d"
            CornerRadius="12"
            BorderBrush="#33ffffff"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="20,16,20,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE895;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="20"
                               Foreground="#60cdff"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBlock Text="发现新版本"
                               FontFamily="Microsoft YaHei"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="#ffffff"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button x:Name="BtnClose"
                        Content="&#xE8BB;"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Foreground="#cccccc"
                        Width="32" Height="32"
                        Click="OnCloseClick"
                        Style="{StaticResource CaptionButton}" />
            </Grid>

            <!-- 分隔线 -->
            <Border Grid.Row="1" Height="1" Background="#1effffff" />

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="20,12,20,12">
                <StackPanel>
                    <!-- 版本信息 -->
                    <Border Background="#252525"
                            CornerRadius="8"
                            BorderBrush="#1effffff"
                            BorderThickness="1"
                            Padding="16,12">
                        <StackPanel>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="当前版本: "
                                               FontFamily="Microsoft YaHei"
                                               FontSize="13"
                                               Foreground="#aaaaaa" />
                                    <TextBlock x:Name="TxtCurrentVersion"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="13"
                                               Foreground="#ffffff" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="最新版本: "
                                               FontFamily="Microsoft YaHei"
                                               FontSize="13"
                                               Foreground="#aaaaaa" />
                                    <TextBlock x:Name="TxtLatestVersion"
                                               FontFamily="Microsoft YaHei"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               Foreground="#60cdff" />
                                </StackPanel>
                            </Grid>

                            <!-- 更新内容 -->
                            <TextBlock Text="更新内容:"
                                       FontFamily="Microsoft YaHei"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#ffffff"
                                       Margin="0,12,0,6" />
                            <Border Background="#1effffff"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    MaxHeight="150">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock x:Name="TxtChangelog"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="12"
                                               Foreground="#cccccc"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 更新方式说明 -->
                    <Border Background="#252525"
                            CornerRadius="8"
                            BorderBrush="#1effffff"
                            BorderThickness="1"
                            Padding="16,12"
                            Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="更新方式"
                                       FontFamily="Microsoft YaHei"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#ffffff"
                                       Margin="0,0,0,6" />
                            <RadioButton x:Name="RadioIncremental"
                                         Content="增量更新（推荐，只下载变化的文件）"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="12"
                                         Foreground="#cccccc"
                                         IsChecked="True"
                                         Margin="0,4" />
                            <RadioButton x:Name="RadioFull"
                                         Content="完整安装包（下载完整安装程序）"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="12"
                                         Foreground="#cccccc"
                                         Margin="0,4" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="3" Background="#252525"
                    CornerRadius="0,0,12,12"
                    Padding="20,12">
                <Grid>
                    <!-- 进度条（默认隐藏） -->
                    <StackPanel x:Name="ProgressPanel"
                                Visibility="Collapsed"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtProgress"
                                   FontFamily="Microsoft YaHei"
                                   FontSize="12"
                                   Foreground="#aaaaaa"
                                   Margin="0,0,0,6" />
                        <Border Background="#1effffff"
                                Height="4"
                                CornerRadius="2">
                            <Border x:Name="ProgressBar"
                                    Background="#60cdff"
                                    HorizontalAlignment="Left"
                                    Height="4"
                                    CornerRadius="2"
                                    Width="0" />
                        </Border>
                    </StackPanel>

                    <!-- 按钮 -->
                    <StackPanel x:Name="ButtonPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="稍后提醒"
                                FontFamily="Microsoft YaHei"
                                FontSize="13"
                                Foreground="#cccccc"
                                Background="Transparent"
                                BorderBrush="#33ffffff"
                                BorderThickness="1"
                                Padding="20,8"
                                Cursor="Hand"
                                Click="OnRemindLaterClick"
                                Margin="0,0,10,0" />
                        <Button x:Name="BtnUpdate"
                                Content="立即更新"
                                FontFamily="Microsoft YaHei"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#ffffff"
                                Background="#60cdff"
                                BorderThickness="0"
                                Padding="20,8"
                                Cursor="Hand"
                                Click="OnUpdateClick"
                                Style="{StaticResource AccentButton}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
