<Window x:Class="陈叔叔工具箱.Controls.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Width="440" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2d2d2d"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CornerRadius="0"
                      CaptionHeight="32"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <!-- 标题栏 -->
    <DockPanel LastChildFill="True" WindowChrome.IsHitTestVisibleInChrome="True">
        <Border DockPanel.Dock="Top" Background="#181818" Height="32">
            <Grid>
                <TextBlock Text="发现新版本"
                           FontFamily="Microsoft YaHei" FontSize="12"
                           Foreground="#cccccc"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <Button Content="&#xE8BB;"
                        HorizontalAlignment="Right"
                        FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Foreground="#cccccc"
                        Width="46" Height="32"
                        Click="OnCloseClick"
                        Style="{StaticResource CaptionClose}" />
            </Grid>
        </Border>

        <!-- 内容 -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 版本对比 -->
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="当前版本"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="11" Foreground="#777777"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtCurrentVersion"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#aaaaaa"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="→"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="24" Foreground="#60cdff"
                                       VerticalAlignment="Center"
                                       Margin="24,0" />
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="最新版本"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="11" Foreground="#777777"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="TxtLatestVersion"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#60cdff"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 更新内容 -->
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="更新内容"
                                       FontFamily="Microsoft YaHei"
                                       FontWeight="SemiBold"
                                       FontSize="12" Foreground="#ffffff"
                                       Margin="0,0,0,6" />
                            <TextBlock x:Name="TxtChangelog"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12" Foreground="#cccccc"
                                       TextWrapping="Wrap"
                                       MaxHeight="100" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="稍后提醒"
                        FontFamily="Microsoft YaHei"
                        FontSize="13" Foreground="#cccccc"
                        Background="#333333"
                        BorderBrush="#44ffffff" BorderThickness="1"
                        Padding="20,8"
                        Cursor="Hand"
                        Click="OnRemindLaterClick"
                        Margin="0,0,10,0" />
                <Button x:Name="BtnUpdate"
                        Content="立即更新"
                        FontFamily="Microsoft YaHei"
                        FontSize="13" FontWeight="SemiBold"
                        Foreground="#ffffff"
                        Background="#4aa8d8"
                        BorderThickness="0"
                        Padding="20,8"
                        Cursor="Hand"
                        Click="OnUpdateClick" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
