<UserControl x:Class="陈叔叔工具箱.Controls.ToolCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="205" Height="140"
             Cursor="Hand">
    <UserControl.Resources>
        <Storyboard x:Key="HoverIn">
            <ColorAnimation Storyboard.TargetName="CardBorder"
                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                            To="#353535" Duration="0:0:0.15" />
            <ColorAnimation Storyboard.TargetName="CardBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#2fffffff" Duration="0:0:0.15" />
        </Storyboard>
        <Storyboard x:Key="HoverOut">
            <ColorAnimation Storyboard.TargetName="CardBorder"
                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                            To="#2d2d2d" Duration="0:0:0.15" />
            <ColorAnimation Storyboard.TargetName="CardBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#33ffffff" Duration="0:0:0.15" />
        </Storyboard>
        <Storyboard x:Key="SelectIn">
            <ColorAnimation Storyboard.TargetName="CardBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#60cdff" Duration="0:0:0.15" />
        </Storyboard>
        <Storyboard x:Key="SelectOut">
            <ColorAnimation Storyboard.TargetName="CardBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#33ffffff" Duration="0:0:0.15" />
        </Storyboard>
    </UserControl.Resources>
    <Border x:Name="CardBorder"
            Background="#2d2d2d"
            BorderBrush="#33ffffff"
            BorderThickness="1"
            CornerRadius="8"
            MouseEnter="OnMouseEnter"
            MouseLeave="OnMouseLeave"
            MouseDown="OnMouseDown">
        <Grid VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Margin="8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Image x:Name="ToolIcon"
                   Grid.Row="0"
                   Width="48" Height="48"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Margin="0,0,0,8" />
            <TextBlock Grid.Row="1"
                       Text="{Binding Name}"
                       FontFamily="Microsoft YaHei"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="#ffffff"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
