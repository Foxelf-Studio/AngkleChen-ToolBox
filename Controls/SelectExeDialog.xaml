<Window x:Class="陈叔叔工具箱.Controls.SelectExeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择主程序"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1f1f1f"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CornerRadius="0"
                      CaptionHeight="32"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#33ffffff" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="1" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#181818"
                    MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="#60cdff"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="选择主程序"
                                   FontFamily="Microsoft YaHei"
                                   FontSize="12"
                                   Foreground="#cccccc"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button Content="&#xE8BB;"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10" Foreground="#cccccc"
                                Width="46" Height="32"
                                Click="OnCancelClick"
                                Style="{StaticResource CaptionClose}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 分隔线 -->
            <Border Grid.Row="1" Height="1" Background="#1effffff" />

            <!-- 内容区域 -->
            <StackPanel Grid.Row="2" Margin="16,12">
                <TextBlock Text="该文件夹包含多个可执行文件，请选择主程序："
                           FontFamily="Microsoft YaHei"
                           FontSize="12"
                           Foreground="#aaaaaa"
                           Margin="0,0,0,12" />

                <ListBox x:Name="ExeListBox"
                         Background="#252525"
                         BorderBrush="#3effffff"
                         BorderThickness="1"
                         Foreground="#ffffff"
                         FontFamily="Microsoft YaHei"
                         FontSize="13"
                         Padding="4"
                         MaxHeight="150"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Margin" Value="0,2" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3a3a3a" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#4aa8d8" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>

            <!-- 分隔线 -->
            <Border Grid.Row="3" Height="1" Background="#1effffff" />

            <!-- 底部按钮 -->
            <Border Grid.Row="4" Background="#252525"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" Foreground="#cccccc"
                            Background="#333333"
                            BorderBrush="#44ffffff" BorderThickness="1"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnCancelClick"
                            Margin="0,0,10,0" />
                    <Button x:Name="BtnSelect"
                            Content="选择"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="#ffffff"
                            Background="#4aa8d8"
                            BorderBrush="#5cb8e8" BorderThickness="1"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnSelectClick"
                            Style="{StaticResource AccentButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
