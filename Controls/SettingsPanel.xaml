<UserControl x:Class="陈叔叔工具箱.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#2d2d2d"
            CornerRadius="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="20,16,20,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           Foreground="#ffffff"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBlock Text="设置"
                           FontFamily="Microsoft YaHei"
                           FontWeight="Bold"
                           FontSize="18"
                           Foreground="#ffffff"
                           VerticalAlignment="Center" />
            </StackPanel>
            <Button x:Name="BtnClose"
                    Content="&#xE8BB;"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="12"
                    Foreground="#cccccc"
                    Width="32" Height="32"
                    Click="OnCloseClick"
                    Style="{StaticResource SmallCaptionButton}" />
        </Grid>

        <!-- 分隔线 -->
        <Border Grid.Row="1" Height="1" Background="#1effffff" />

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,12,20,20">
            <StackPanel>
                <!-- 关于分组 -->
                <TextBlock Text="关于"
                           FontFamily="Microsoft YaHei"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#777777"
                           Margin="0,0,0,8" />
                <Border Background="#252525"
                        CornerRadius="8"
                        BorderBrush="#1effffff"
                        BorderThickness="1"
                        Padding="16,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/logo.png"
                                   Width="48" Height="48"
                                   Margin="0,0,12,0"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="陈叔叔工具箱"
                                           FontFamily="Microsoft YaHei"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="#ffffff" />
                                <TextBlock x:Name="TxtVersion"
                                           Text="v1.2.0"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="12"
                                           Foreground="#aaaaaa"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="⭐陈叔叔出品 必属精品⭐"
                                   FontFamily="Microsoft YaHei"
                                   FontSize="12"
                                   Foreground="#777777"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <!-- 更新分组 -->
                <TextBlock Text="更新"
                           FontFamily="Microsoft YaHei"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#777777"
                           Margin="0,16,0,8" />
                <Border Background="#252525"
                        CornerRadius="8"
                        BorderBrush="#1effffff"
                        BorderThickness="1"
                        Padding="16,12">
                    <StackPanel>
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#60cdff"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="检查更新"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="14"
                                               Foreground="#ffffff" />
                                    <TextBlock x:Name="TxtUpdateStatus"
                                               Text="点击检查是否有新版本"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="11"
                                               Foreground="#777777"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="BtnCheckUpdate"
                                    Content="检查更新"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="Microsoft YaHei"
                                    FontSize="12"
                                    Foreground="#ffffff"
                                    Background="#60cdff"
                                    BorderThickness="0"
                                    Padding="16,6"
                                    Cursor="Hand"
                                    Click="OnCheckUpdateClick"
                                    Style="{StaticResource AccentButton}" />
                        </Grid>

                        <!-- 更新进度（默认隐藏） -->
                        <Border x:Name="UpdateProgressPanel"
                                Visibility="Collapsed"
                                Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock x:Name="TxtUpdateProgress"
                                           Text="正在下载更新..."
                                           FontFamily="Microsoft YaHei"
                                           FontSize="12"
                                           Foreground="#aaaaaa" />
                                <Border Background="#1effffff"
                                        Height="4"
                                        CornerRadius="2"
                                        Margin="0,6,0,0">
                                    <Border x:Name="ProgressBar"
                                            Background="#60cdff"
                                            HorizontalAlignment="Left"
                                            Height="4"
                                            CornerRadius="2"
                                            Width="0" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 设置分组 -->
                <TextBlock Text="设置"
                           FontFamily="Microsoft YaHei"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#777777"
                           Margin="0,16,0,8" />
                <Border Background="#252525"
                        CornerRadius="8"
                        BorderBrush="#1effffff"
                        BorderThickness="1"
                        Padding="16,12">
                    <StackPanel>
                        <Grid Height="40">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#aaaaaa"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="启动时检查更新"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="14"
                                           Foreground="#ffffff"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ToggleButton x:Name="ToggleAutoCheck"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          IsChecked="True"
                                          Checked="OnAutoCheckChanged"
                                          Unchecked="OnAutoCheckChanged"
                                          Style="{StaticResource Win11Toggle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 链接分组 -->
                <TextBlock Text="链接"
                           FontFamily="Microsoft YaHei"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#777777"
                           Margin="0,16,0,8" />
                <Button x:Name="BtnGitHub"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Click="OnGitHubClick"
                        Style="{StaticResource LinkButton}"
                        Background="#252525"
                        BorderBrush="#1effffff"
                        BorderThickness="1"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="#aaaaaa"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GitHub 仓库"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="14"
                                       Foreground="#ffffff" />
                            <TextBlock Text="查看源码和更新日志"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="11"
                                       Foreground="#777777"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    </Border>
</UserControl>
