<Window x:Class="陈叔叔工具箱.Controls.AddToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加工具"
        Width="500" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2d2d2d"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CornerRadius="8"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"
                      CaptionHeight="0" />
    </WindowChrome.WindowChrome>

    <Border Background="#2d2d2d"
            CornerRadius="8"
            BorderBrush="#33ffffff"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="#181818"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="#60cdff"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="添加工具"
                                   FontFamily="Microsoft YaHei"
                                   FontSize="12"
                                   Foreground="#cccccc"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                    <Button Content="&#xE8BB;"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#cccccc"
                            Width="46" Height="32"
                            Click="OnCloseClick"
                            Style="{StaticResource CaptionClose}" />
                </Grid>
            </Border>

            <!-- 分隔线 -->
            <Border Grid.Row="1" Height="1" Background="#1effffff" />

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Margin="16">
                <StackPanel>
                    <!-- 步骤 1 -->
                    <TextBlock Text="步骤 1：选择添加方式"
                               FontFamily="Microsoft YaHei"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#777777"
                               Margin="0,0,0,8" />
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <RadioButton x:Name="RadioFolder"
                                         Content="选择文件夹"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         IsChecked="True"
                                         Margin="0,4" />
                            <RadioButton x:Name="RadioFile"
                                         Content="选择文件"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         Margin="0,4" />
                            <Button x:Name="BtnBrowse"
                                    Content="浏览..."
                                    HorizontalAlignment="Left"
                                    FontFamily="Microsoft YaHei"
                                    FontSize="12"
                                    Foreground="#ffffff"
                                    Background="#4aa8d8"
                                    BorderBrush="#5cb8e8" BorderThickness="1"
                                    Padding="16,6"
                                    Margin="0,8,0,0"
                                    Click="OnBrowseClick"
                                    Style="{StaticResource AccentButton}" />
                            <TextBlock x:Name="TxtSelectedPath"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="11"
                                       Foreground="#777777"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- 步骤 2 -->
                    <TextBlock Text="步骤 2：填写工具信息"
                               FontFamily="Microsoft YaHei"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#777777"
                               Margin="0,16,0,8" />
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="工具名称 *"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12"
                                       Foreground="#aaaaaa"
                                       Margin="0,0,0,4" />
                            <Border Background="#1effffff" CornerRadius="4"
                                    BorderBrush="#3effffff" BorderThickness="1"
                                    Padding="8,6" Margin="0,0,0,10">
                                <TextBox x:Name="TxtToolName"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#ffffff"
                                         Background="Transparent"
                                         BorderThickness="0" />
                            </Border>
                            <TextBlock Text="工具描述（选填）"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12"
                                       Foreground="#aaaaaa"
                                       Margin="0,0,0,4" />
                            <Border Background="#1effffff" CornerRadius="4"
                                    BorderBrush="#3effffff" BorderThickness="1"
                                    Padding="8,6">
                                <TextBox x:Name="TxtToolDesc"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#ffffff"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="60"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 步骤 3 -->
                    <TextBlock Text="步骤 3：选择分类"
                               FontFamily="Microsoft YaHei"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#777777"
                               Margin="0,16,0,8" />
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <RadioButton x:Name="RadioExistingCategory"
                                         Content="选择已有分类"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         IsChecked="True"
                                         Margin="0,4" />
                            <!-- 自定义下拉框 -->
                            <Border x:Name="ComboBorder"
                                    Background="#2b2b2b" CornerRadius="4"
                                    BorderBrush="#3effffff" BorderThickness="1"
                                    Margin="0,6,0,10"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="OnComboClick">
                                <Grid>
                                    <TextBlock x:Name="TxtSelectedCategory"
                                               Text="请选择分类"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="13"
                                               Foreground="#ffffff"
                                               VerticalAlignment="Center"
                                               Margin="8,6,30,6" />
                                    <TextBlock Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="10"
                                               Foreground="#aaaaaa"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                </Grid>
                            </Border>
                            <!-- 下拉列表 -->
                            <Border x:Name="DropDownPanel"
                                    Background="#2b2b2b" CornerRadius="4"
                                    BorderBrush="#3effffff" BorderThickness="1"
                                    MaxHeight="150"
                                    Visibility="Collapsed">
                                <ListBox x:Name="CategoryListBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#ffffff"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         SelectionChanged="OnCategorySelected"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="8,6" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3a3a3a" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#4aa8d8" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>
                            <RadioButton x:Name="RadioNewCategory"
                                         Content="创建新分类"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         Margin="0,4" />
                            <Border Background="#1effffff" CornerRadius="4"
                                    BorderBrush="#3effffff" BorderThickness="1"
                                    Padding="8,6" Margin="0,6,0,0">
                                <TextBox x:Name="TxtNewCategory"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#ffffff"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsEnabled="False" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="3" Background="#252525"
                    CornerRadius="0,0,8,8"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" Foreground="#cccccc"
                            Background="#333333"
                            BorderBrush="#44ffffff" BorderThickness="1"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnCancelClick"
                            Margin="0,0,10,0" />
                    <Button x:Name="BtnFinish"
                            Content="完成"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="#ffffff"
                            Background="#4aa8d8"
                            BorderBrush="#5cb8e8" BorderThickness="1"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnFinishClick"
                            Style="{StaticResource AccentButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
