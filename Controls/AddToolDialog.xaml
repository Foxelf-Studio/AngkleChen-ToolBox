<Window x:Class="陈叔叔工具箱.Controls.AddToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加工具"
        Width="500" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="#2d2d2d"
            CornerRadius="12"
            BorderBrush="#33ffffff"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="20,16,20,12">
                <TextBlock Text="添加工具"
                           FontFamily="Microsoft YaHei"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="#ffffff"
                           VerticalAlignment="Center" />
                <Button Content="&#xE8BB;"
                        HorizontalAlignment="Right"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12" Foreground="#cccccc"
                        Width="32" Height="32"
                        Click="OnCloseClick"
                        Style="{StaticResource SmallCaptionButton}" />
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#1effffff" />

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Margin="20,16,20,12">
                <StackPanel>
                    <!-- 步骤 1：选择添加类型 -->
                    <TextBlock Text="步骤 1：选择添加方式"
                               FontFamily="Microsoft YaHei"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#777777"
                               Margin="0,0,0,8" />
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <RadioButton x:Name="RadioFolder"
                                         Content="选择文件夹"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         IsChecked="True"
                                         Margin="0,4" />
                            <RadioButton x:Name="RadioFile"
                                         Content="选择文件"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         Margin="0,4" />
                            <Button x:Name="BtnBrowse"
                                    Content="浏览..."
                                    HorizontalAlignment="Left"
                                    FontFamily="Microsoft YaHei"
                                    FontSize="12"
                                    Foreground="#ffffff"
                                    Background="#60cdff"
                                    BorderThickness="0"
                                    Padding="16,6"
                                    Margin="0,8,0,0"
                                    Click="OnBrowseClick"
                                    Style="{StaticResource AccentButton}" />
                            <TextBlock x:Name="TxtSelectedPath"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="11"
                                       Foreground="#777777"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- 步骤 2：基本信息 -->
                    <TextBlock Text="步骤 2：填写工具信息"
                               FontFamily="Microsoft YaHei"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#777777"
                               Margin="0,16,0,8" />
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="工具名称 *"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12"
                                       Foreground="#aaaaaa"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="TxtToolName"
                                     FontFamily="Microsoft YaHei"
                                     FontSize="13"
                                     Foreground="#ffffff"
                                     Background="#1effffff"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     Margin="0,0,0,10" />
                            <TextBlock Text="工具描述（选填）"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12"
                                       Foreground="#aaaaaa"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="TxtToolDesc"
                                     FontFamily="Microsoft YaHei"
                                     FontSize="13"
                                     Foreground="#ffffff"
                                     Background="#1effffff"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     Height="60"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True" />
                        </StackPanel>
                    </Border>

                    <!-- 步骤 3：选择分类 -->
                    <TextBlock Text="步骤 3：选择分类"
                               FontFamily="Microsoft YaHei"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#777777"
                               Margin="0,16,0,8" />
                    <Border Background="#252525" CornerRadius="8"
                            BorderBrush="#1effffff" BorderThickness="1"
                            Padding="12,10">
                        <StackPanel>
                            <RadioButton x:Name="RadioExistingCategory"
                                         Content="选择已有分类"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         IsChecked="True"
                                         Margin="0,4" />
                            <ComboBox x:Name="ComboCategories"
                                      FontFamily="Microsoft YaHei"
                                      FontSize="13"
                                      Foreground="#ffffff"
                                      Background="#1effffff"
                                      Padding="8,6"
                                      Margin="0,6,0,10" />
                            <RadioButton x:Name="RadioNewCategory"
                                         Content="创建新分类"
                                         FontFamily="Microsoft YaHei"
                                         FontSize="13"
                                         Foreground="#cccccc"
                                         Margin="0,4" />
                            <TextBox x:Name="TxtNewCategory"
                                     FontFamily="Microsoft YaHei"
                                     FontSize="13"
                                     Foreground="#ffffff"
                                     Background="#1effffff"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     Margin="0,6,0,0"
                                     IsEnabled="False" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="3" Background="#252525"
                    CornerRadius="0,0,12,12"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" Foreground="#cccccc"
                            Background="Transparent"
                            BorderBrush="#33ffffff" BorderThickness="1"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnCancelClick"
                            Margin="0,0,10,0" />
                    <Button x:Name="BtnFinish"
                            Content="完成"
                            FontFamily="Microsoft YaHei"
                            FontSize="13" FontWeight="SemiBold"
                            Foreground="#ffffff"
                            Background="#60cdff"
                            BorderThickness="0"
                            Padding="20,8"
                            Cursor="Hand"
                            Click="OnFinishClick"
                            Style="{StaticResource AccentButton}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
