<Window x:Class="陈叔叔工具箱.Controls.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在复制文件"
        Width="400" Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1f1f1f"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CornerRadius="0"
                      CaptionHeight="32"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#181818"
                MouseLeftButtonDown="TitleBar_Drag">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <TextBlock Text="&#xE896;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Foreground="#60cdff"
                               VerticalAlignment="Center" />
                    <TextBlock Text="正在复制文件"
                               FontFamily="Microsoft YaHei"
                               FontSize="12"
                               Foreground="#cccccc"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 分隔线 -->
        <Border Grid.Row="1" Height="1" Background="#1effffff" />

        <!-- 内容区域 -->
        <StackPanel Grid.Row="2" Margin="20,20,20,20"
                    VerticalAlignment="Center">
            <TextBlock x:Name="TxtStatus"
                       Text="正在复制文件..."
                       FontFamily="Microsoft YaHei"
                       FontSize="13"
                       Foreground="#ffffff"
                       Margin="0,0,0,12" />

            <!-- 进度条背景 -->
            <Border Background="#252525"
                    CornerRadius="4"
                    Height="8">
                <!-- 进度条 -->
                <Border x:Name="ProgressBar"
                        Background="#4aa8d8"
                        CornerRadius="4"
                        HorizontalAlignment="Left"
                        Width="0" />
            </Border>

            <TextBlock x:Name="TxtProgress"
                       Text="0%"
                       FontFamily="Microsoft YaHei"
                       FontSize="11"
                       Foreground="#777777"
                       HorizontalAlignment="Right"
                       Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</Window>
