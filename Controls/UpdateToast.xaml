<Window x:Class="陈叔叔工具箱.Controls.UpdateToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="230" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Border Background="#2b2b2b"
            CornerRadius="8"
            BorderBrush="#3effffff"
            BorderThickness="1"
            Margin="0">
        <Grid Margin="10,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题行 -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE895;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="#60cdff"
                               VerticalAlignment="Center" />
                    <TextBlock Text="发现新版本"
                               FontFamily="Microsoft YaHei"
                               FontSize="11"
                               Foreground="#ffffff"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0" />
                </StackPanel>
                <Button Content="&#xE8BB;"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="8"
                        Foreground="#777777"
                        Width="16" Height="16"
                        Click="OnCloseClick"
                        Style="{StaticResource SmallCaptionButton}" />
            </Grid>

            <!-- 描述 -->
            <TextBlock Grid.Row="1"
                       Text="有新的更新可用"
                       FontFamily="Microsoft YaHei"
                       FontSize="11"
                       Foreground="#aaaaaa"
                       VerticalAlignment="Center" />

            <!-- 按钮 -->
            <Button Grid.Row="2"
                    Content="查看更新"
                    HorizontalAlignment="Left"
                    FontFamily="Microsoft YaHei"
                    FontSize="11"
                    Foreground="#ffffff"
                    Background="#4aa8d8"
                    BorderBrush="#5cb8e8" BorderThickness="1"
                    Padding="12,3"
                    Cursor="Hand"
                    Click="OnViewUpdateClick"
                    Style="{StaticResource AccentButton}" />
        </Grid>
    </Border>
</Window>
