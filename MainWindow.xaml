<Window x:Class="陈叔叔工具箱.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:陈叔叔工具箱.Controls"
        xmlns:helpers="clr-namespace:陈叔叔工具箱.Helpers"
        Title="陈叔叔工具箱"
        Icon="logo.png"
        Width="1260" Height="780"
        MinWidth="960" MinHeight="580"
        Background="#1f1f1f"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1"
                      CornerRadius="8"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False"
                      CaptionHeight="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ 自定义标题栏 ═══════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#181818"
                MouseLeftButtonDown="TitleBar_Drag">
            <Grid>
                <!-- 左侧：图标 + 标题 -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Image Source="logo.png"
                           Width="16" Height="16"
                           VerticalAlignment="Center" />
                    <TextBlock Text="陈叔叔工具箱"
                               FontFamily="Microsoft YaHei"
                               FontSize="12"
                               Foreground="#cccccc"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <!-- 右侧：窗口控制按钮 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button x:Name="BtnAddTool" Content="&#xE710;"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14" Foreground="#cccccc"
                            Width="46" Height="32"
                            Click="OnAddTool"
                            Style="{StaticResource CaptionButton}" />
                    <Button x:Name="BtnSettings" Content="&#xE713;"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14" Foreground="#cccccc"
                            Width="46" Height="32"
                            Click="OnSettings"
                            Style="{StaticResource CaptionButton}" />
                    <Button x:Name="BtnMin" Content="&#xE949;"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#cccccc"
                            Width="46" Height="32"
                            Click="OnMinimize"
                            Style="{StaticResource CaptionButton}" />
                    <Button x:Name="BtnMax" Content="&#xE922;"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#cccccc"
                            Width="46" Height="32"
                            Click="OnMaximize"
                            Style="{StaticResource CaptionButton}" />
                    <Button x:Name="BtnClose" Content="&#xE8BB;"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10" Foreground="#cccccc"
                            Width="46" Height="32"
                            Click="OnClose"
                            Style="{StaticResource CaptionClose}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ 侧边栏 ═══════ -->
        <Border Grid.Row="1" Grid.Column="0" Background="#181818"
                Padding="12,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="14,24,14,0">
                    <Image Source="logo.png"
                           Width="52" Height="52"
                           HorizontalAlignment="Left" />
                    <TextBlock Text="陈叔叔工具箱"
                               FontFamily="Microsoft YaHei" FontWeight="Bold"
                               FontSize="17" Foreground="#ffffff"
                               Margin="0,4,0,0" />
                    <TextBlock Text="⭐陈叔叔出品 必属精品⭐"
                               FontFamily="Microsoft YaHei" FontSize="11"
                               Foreground="#777777" Margin="0,2,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Height="1" Background="#1effffff"
                        Margin="20,14,20,4" />

                <TextBlock Grid.Row="2" Text="导航"
                           FontFamily="Microsoft YaHei" FontWeight="SemiBold"
                           FontSize="11" Foreground="#777777"
                           Margin="15,0,0,4" />

                <ListBox x:Name="CategoryList" Grid.Row="3"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="OnCategoryChanged"
                         Margin="4,0,4,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False"
                         helpers:SmoothScrollBehavior.IsEnabled="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Height" Value="40" />
                            <Setter Property="Margin" Value="0,1,0,1" />
                            <Setter Property="Padding" Value="14,0,0,0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <EventSetter Event="MouseEnter" Handler="NavItem_MouseEnter" />
                            <EventSetter Event="MouseLeave" Handler="NavItem_MouseLeave" />
                            <EventSetter Event="MouseRightButtonDown" Handler="NavItem_RightClick" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!-- 指示条：初始隐藏，选中时动画滑入 -->
                                                <Border Name="Indicator" Grid.Column="0"
                                                        Background="#60cdff" CornerRadius="2"
                                                        Width="3" Height="0"
                                                        VerticalAlignment="Center"
                                                        Margin="-17,0,6,0" />
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd"
                                                        Property="Background" Value="#18ffffff" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IconGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" Foreground="#ffffff"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Microsoft YaHei" FontSize="14"
                                           Foreground="#ffffff"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="4" Height="1" Background="#1effffff"
                        Margin="20,0,20,4" />

                <TextBlock Grid.Row="5" Margin="20,2,20,12"
                           FontFamily="Microsoft YaHei" FontSize="11"
                           Foreground="#777777"
                           Text="{Binding StatusText}" />
            </Grid>
        </Border>

        <!-- ═══════ 主内容区 ═══════ -->
        <Border Grid.Row="1" Grid.Column="1" Background="#1f1f1f"
                BorderBrush="#1effffff" BorderThickness="1,0,0,0"
                ClipToBounds="True">
            <Grid x:Name="ContentGrid" Margin="32,24,32,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontFamily="Microsoft YaHei" FontSize="11"
                           Foreground="#777777"
                           Text="{Binding Breadcrumb}" />

                <Grid Grid.Row="1" Margin="0,2,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding HeaderTitle}"
                                   FontFamily="Microsoft YaHei" FontWeight="Bold"
                                   FontSize="28" Foreground="#ffffff" />
                        <TextBlock Text="{Binding HeaderSubtitle}"
                                   FontFamily="Microsoft YaHei" FontSize="14"
                                   Foreground="#aaaaaa"
                                   VerticalAlignment="Bottom"
                                   Margin="10,0,0,4" />
                    </StackPanel>
                </Grid>

                <!-- 描述面板：单击工具卡片后显示 -->
                <!-- 描述面板：始终显示 -->
                <Border Grid.Row="2" Background="#252525"
                        CornerRadius="8"
                        BorderBrush="#1effffff" BorderThickness="1"
                        Margin="0,0,0,10">
                    <Grid Margin="16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 选中工具时显示 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding DescDetailVisible}">
                            <Image x:Name="DescIcon" Width="40" Height="40"
                                   Source="{Binding SelectedToolIcon}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="0,0,12,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedToolName}"
                                           FontFamily="Microsoft YaHei" FontWeight="Bold"
                                           FontSize="18" Foreground="#ffffff" />
                                <TextBlock Text="{Binding SelectedToolCategory}"
                                           FontFamily="Microsoft YaHei" FontSize="11"
                                           Foreground="#60cdff" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedToolDescription}"
                                   FontFamily="Microsoft YaHei" FontSize="13"
                                   Foreground="#cccccc"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Margin="20,0,16,0"
                                   Visibility="{Binding DescDetailVisible}" />
                        <TextBlock Grid.Column="2"
                                   Text="双击启动"
                                   FontFamily="Microsoft YaHei" FontSize="11"
                                   Foreground="#777777"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding DescDetailVisible}" />

                        <!-- 未选中工具时显示占位 -->
                        <Grid Grid.ColumnSpan="3"
                              Visibility="{Binding DescPlaceholderVisible}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- 左侧：带图标的占位区 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Width="40" Height="40"
                                        CornerRadius="20"
                                        Background="#1effffff"
                                        Margin="0,0,12,0">
                                    <TextBlock Text=" "
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="18"
                                               Foreground="#555555"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="选择一个工具"
                                               FontFamily="Microsoft YaHei" FontWeight="SemiBold"
                                               FontSize="16" Foreground="#666666" />
                                    <TextBlock Text="单击卡片查看详情"
                                               FontFamily="Microsoft YaHei" FontSize="10"
                                               Foreground="#444444" Margin="0,2,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <!-- 右侧：提示文字 -->
                            <TextBlock Grid.Column="1"
                                       Text="双击工具卡片即可启动"
                                       FontFamily="Microsoft YaHei" FontSize="11"
                                       Foreground="#444444"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="20,0,16,0" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#2b2b2b"
                        CornerRadius="8" Height="42"
                        BorderBrush="#1effffff" BorderThickness="1"
                        Margin="0,0,0,12">
                    <Grid>
                        <TextBlock Text=""
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="#aaaaaa"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" />
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#ffffff"
                                 CaretBrush="#ffffff"
                                 FontFamily="Microsoft YaHei" FontSize="14"
                                 VerticalContentAlignment="Center"
                                 Margin="38,0,12,0"
                                 TextChanged="OnSearchTextChanged" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="4"
                              x:Name="CardScrollViewer"
                              CanContentScroll="False"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalOnly"
                              RenderOptions.BitmapScalingMode="LowQuality"
                              helpers:SmoothScrollBehavior.IsEnabled="True">
                    <ItemsControl x:Name="CardItems">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ToolCard x:Name="ToolCardCtrl"
                                                   DataContext="{Binding}"
                                                   ClickCommand="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   SelectCommand="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   DeleteCommand="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Margin="5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 状态栏 -->
                <TextBlock Grid.Row="5"
                           Text="{Binding StatusTip}"
                           FontFamily="Microsoft YaHei" FontSize="11"
                           Foreground="#777777"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Left" />

                <!-- 更新提示气泡 -->
                <Border x:Name="UpdateToastPanel"
                        Grid.Row="0" Grid.RowSpan="5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="220" Height="75"
                        Background="#2b2b2b"
                        CornerRadius="8"
                        BorderBrush="#3effffff"
                        BorderThickness="1"
                        Margin="0,-20,8,0"
                        Visibility="Collapsed">
                    <Grid Margin="10,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 标题行 -->
                        <Grid Grid.Row="0" Margin="0,-4,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE895;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="#60cdff"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="发现新版本"
                                           FontFamily="Microsoft YaHei"
                                           FontSize="11"
                                           Foreground="#ffffff"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0" />
                            </StackPanel>
                            <Button Content="&#xE8BB;"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="8"
                                    Foreground="#777777"
                                    Width="15" Height="15"
                                    Margin="0,-7,-10,0"
                                    Click="OnToastCloseClick"
                                    Style="{StaticResource ToastCloseButton}" />
                        </Grid>

                        <!-- 描述 -->
                        <TextBlock Grid.Row="1"
                                   Text="有新的更新可用"
                                   FontFamily="Microsoft YaHei"
                                   FontSize="11"
                                   Foreground="#aaaaaa"
                                   VerticalAlignment="Center"
                                   Margin="0,-4,0,0" />

                        <!-- 按钮 -->
                        <Button Grid.Row="2"
                                Content="查看更新"
                                HorizontalAlignment="Left"
                                FontFamily="Microsoft YaHei"
                                FontSize="11"
                                Foreground="#ffffff"
                                Background="#4aa8d8"
                                BorderBrush="#5cb8e8" BorderThickness="1"
                                Padding="12,3"
                                Cursor="Hand"
                                Click="OnToastViewClick"
                                Style="{StaticResource AccentButton}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ 设置页面覆盖层 ═══════ -->
        <Border x:Name="SettingsOverlay"
                Grid.RowSpan="2" Grid.ColumnSpan="2"
                Background="#80000000"
                Visibility="Collapsed"
                MouseLeftButtonDown="OnSettingsOverlayClick">
            <controls:SettingsPanel x:Name="SettingsPanelCtrl"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    Width="400"
                                    CloseRequested="OnSettingsCloseRequested" />
        </Border>
    </Grid>
</Window>
